# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/emergencias_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera una clave aleatoria larga (ej: openssl rand -hex 32)
SECRET_KEY=cambia_esta_clave_por_una_muy_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Firebase (notificaciones push — Ciclo 2) ──────────────────────────────────
# Ruta al archivo de credenciales descargado de Firebase Console
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# ── IA (Ciclo 2) ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
